PORT=3000


# 개발 환경 주소
CORS_ORIGINS_DEV="http://localhost:5173"
# 운영 주소
CORS_ORIGINS_PROD="http://localhost:5173"
CLIENT_URL=http://localhost:3000

DATABASE_URL="postgresql://root:1234@localhost:5432/Project?schema=public"
DIRECT_URL="postgresql://root:1234@localhost:5432/Project"
# PostgreSQL connection pool max per Render instance
# Aiven Free(max_connections=20) + Render 1 instance 기준 권장값: 9
DB_POOL_MAX=9

# 카카오 API 사용 시 필요
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Brevo (https://brevo.com) - 300건/일 무료, 도메인 인증 불필요
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=your-email@gmail.com
BREVO_FROM_NAME=T-LECTURE

# JWT 시크릿 키 설정
JWT_SECRET="my_super_secure_secret_key"
JWT_REFRESH_SECRET=your_refresh_secret_key
# 공지 첨부 다운로드 토큰 전용 시크릿 (운영 권장)
NOTICE_ATTACHMENT_DOWNLOAD_SECRET=your_notice_attachment_download_secret

# 초기 설정 (Seed용)

SUPER_ADMIN_EMAIL=admin@t-lecture.com
SUPER_ADMIN_PASSWORD=admin

GENERAL_ADMIN_EMAIL=general@t-lecture.com
GENERAL_ADMIN_PASSWORD=general

INSTRUCTOR_EMAIL=instructor@t-lecture.com
INSTRUCTOR_PASSWORD=instructor

# 디버그 로그를 파일에도 저장할지 (logs/debug/ 폴더)
# DEBUG_TO_FILE=true
DEBUG_TO_FILE=false
BATCH_API_SECRET=your_batch_api_secret
NOTICE_ATTACHMENT_TTL_DAYS=7



# ========================================
# Sentry (Error Tracking)
# ========================================
# Sentry에서 프로젝트 생성 후 DSN을 복사하여 붙여넣으세요
# https://sentry.io
SENTRY_DSN=
# 성능 추적 샘플링 비율 (0~1). 운영은 0.05~0.1 권장
SENTRY_TRACES_SAMPLE_RATE=0.1
# Node 프로파일링은 별도 도입 전까지 0 유지 권장
SENTRY_PROFILES_SAMPLE_RATE=0

# k6 부하 테스트 연동용 (URL에서 확인 가능: one.newrelic.com/xxxx/account/1234567 의 숫자)
NEW_RELIC_ACCOUNT_ID=

# "development" or "production"
NODE_ENV="development"
